
# Database & Cache (MongoDB / Redis)
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<appName>"
MONGODB_DB_NAME=BlueEyeEntertainment
MONGODB_DB_COLLECTION_NAME=artists
REDIS_URL="rediss://default:<password>@<host>.upstash.io:6379"

# Authentication (NextAuth & Admin Credentials)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_PASSWORD=your_admin_password_here

# File Uploads (ImageKit)
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_endpoint
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_endpoint

# Email Service (Resend)
RESEND_API=your_resend_api_key
EMAIL_TO=your_email_to@example.com

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# Brand Identity & App URLs
NEXT_PUBLIC_BRAND_NAME="Blue Eye Entertainment"
NEXT_PUBLIC_BRAND_SHORT_NAME=BlueEyeEntertainment
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Social Media Links
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/BlueEyeEntertainment
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/theblueeyeentertainment
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/BlueEyeEntertainment
NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@BlueEyeEntertainment
NEXT_PUBLIC_TWITTER_HANDLE=@BlueEyeEntertainment

# Contact Information
NEXT_PUBLIC_CONTACT_EMAIL=theblueeyeentertainment@gmail.com
NEXT_PUBLIC_CONTACT_PHONE="+91 91379 52580"
NEXT_PUBLIC_CONTACT_ADDRESS_1="43W. Bediyadanga masjid bari bye lane. Ground Floor.Groud floor. Kolkata"
NEXT_PUBLIC_CONTACT_ADDRESS_2="A 1501Ekta suprabhat, Siddharth nagar, Goregaon w , Mumbai 400104"

# WhatsApp Integration
WHATSAPP_PHONE_NUMBER=919137952580

# SEO & Site Verification
GOOGLE_SITE_VERIFICATION="your_google_site_verification"
BING_SITE_VERIFICATION="your_bing_site_verification"

# Redis Cache Keys & Settings
REDIS_CACHE_KEY_PREFIX=theblueeyeentertainment

# Home Page Data
HOME_DATA_REDIS_CACHE_KEY=theblueeyeentertainment:home:data
HOME_DATA_CACHE_TTL_SECONDS=600
NEXT_PUBLIC_HOME_CLIENT_CACHE_KEY=theblueeyeentertainment_home_data

# Auth Pending User
AUTH_PENDING_USER_CACHE_PREFIX=theblueeyeentertainment:auth:pending-user
AUTH_PENDING_USER_TTL_SECONDS=600

# User Favorites
USER_FAVORITES_CACHE_PREFIX=theblueeyeentertainment:user:favorites
USER_FAVORITES_IDS_CACHE_PREFIX=theblueeyeentertainment:user:favorites-ids
USER_FAVORITES_CACHE_TTL_SECONDS=1800

# User Reviews & Marquee
REVIEWS_ALL_MARQUEE_CACHE_KEY=theblueeyeentertainment:reviews:marquee
REVIEWS_ALL_MARQUEE_CACHE_TTL_SECONDS=300
USER_REVIEW_CACHE_PREFIX=theblueeyeentertainment:user:review
REVIEWS_MINE_CACHE_TTL_SECONDS=300
