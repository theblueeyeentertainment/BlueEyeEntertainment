# =============================================================================
# Blue Eye Entertainment — environment template
# Copy to `.env.local` and fill in values. Never commit `.env.local`.
# =============================================================================

# --- Database ---
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=BlueEye
MONGODB_DB_COLLECTION_NAME=artists

# --- Redis (optional; caching falls back if unavailable) ---
REDIS_URL=redis://localhost:6379

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# Admin (credentials login)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-dev-password
ADMIN_PASSWORD_HASH=bcrypt_hash_of_admin_password

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- ImageKit ---
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# --- Email (Resend) ---
RESEND_API=
EMAIL_TO=bookings@example.com

# --- WhatsApp (Baileys / Click-to-Chat) ---
WHATSAPP_PHONE_NUMBER=

# --- SEO verification (optional) ---
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# --- Public brand & site (NEXT_PUBLIC_* exposed to browser) ---
NEXT_PUBLIC_BRAND_NAME=Blue Eye Entertainment
NEXT_PUBLIC_BRAND_SHORT_NAME=BlueEye
NEXT_PUBLIC_BASE_URL=http://localhost:3000

NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_YOUTUBE_URL=
NEXT_PUBLIC_TWITTER_HANDLE=
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.com
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_ADDRESS=

# =============================================================================
# Recently added
# Cache keys & TTLs (optional — defaults use prefix "blueeye")
# =============================================================================

# Global prefix for auto-generated Redis keys
REDIS_CACHE_KEY_PREFIX=blueeye

# Home page — server Redis cache
HOME_DATA_REDIS_CACHE_KEY=blueeye:home:data
HOME_DATA_CACHE_TTL_SECONDS=600

# Home page — browser sessionStorage (must be NEXT_PUBLIC_ for client)
NEXT_PUBLIC_HOME_CLIENT_CACHE_KEY=blueeye_home_data

# Auth — pending registration (email verification)
AUTH_PENDING_USER_CACHE_PREFIX=blueeye:auth:pending-user
AUTH_PENDING_USER_TTL_SECONDS=600

# User favorites
USER_FAVORITES_CACHE_PREFIX=blueeye:user:favorites
USER_FAVORITES_IDS_CACHE_PREFIX=blueeye:user:favorites-ids
USER_FAVORITES_CACHE_TTL_SECONDS=1800

# Reviews
REVIEWS_ALL_MARQUEE_CACHE_KEY=blueeye:reviews:marquee
REVIEWS_ALL_MARQUEE_CACHE_TTL_SECONDS=300
USER_REVIEW_CACHE_PREFIX=blueeye:user:review
REVIEWS_MINE_CACHE_TTL_SECONDS=300
